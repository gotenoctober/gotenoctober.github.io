---
import "../styles/global.css";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="mytheme">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ten October — Custom Web & Mobile App Development</title>
    <meta name="description" content="Since 2011, Ten October has helped ground-level startups take their web and mobile apps from 0 to 1." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <main class="flex-1 flex flex-col items-center justify-center px-6 pt-12 sm:pt-0">
      <div class="flex flex-col items-center gap-8 max-w-2xl w-full">
        <img src="/logo.svg" alt="Ten October" class="w-72" />

        <p class="text-center text-lg leading-relaxed">
          Ten October is a tiny app development studio headquartered in
          Carmel, Indiana. Since 2011, we've partnered with ground-level
          startups in ecommerce, social media, email marketing, remote coworking,
          and GenAI/ML, taking their web and mobile apps
          from idea to reality to launch.
        </p>

        <a href="mailto:support@tenoctober.com" class="btn btn-primary uppercase py-5">
          Get in Touch
        </a>
      </div>

      <section class="mt-16 mb-12 flex flex-col items-center gap-8 px-6 w-full max-w-2xl">
        <h2>Our Apps</h2>

        <div class="card card-lg sm:card-side bg-base-200 w-full">
          <figure class="px-6 pt-6 pb-2 sm:p-6 shrink-0 max-sm:justify-center">
            <img
              src="/lostbooks.jpg"
              alt="Lost Books"
              class="rounded-2xl w-28 h-28"
            />
          </figure>
          <div class="card-body max-sm:pt-2">
            <h3>Lost Books</h3>
            <p class="text-sm opacity-60 -mt-1">A cozy mobile puzzle game</p>
            <p>
              Someone has rearranged the library overnight. Books are missing
              from every shelf, and the only way to find them is to think. Each
              puzzle is a grid of colorful shelves, and somewhere in each row,
              each column, and each colored section, exactly one book is hiding.
              Your job is to figure out where.
            </p>
            <div class="flex flex-wrap items-center gap-2 mt-2">
              <div class="relative flex flex-col items-center">
                <span class="opacity-30 grayscale cursor-not-allowed">
                  <img
                    src="https://developer.apple.com/assets/elements/badges/download-on-the-app-store.svg"
                    alt="Download on the App Store"
                    class="h-10"
                  />
                </span>
                <span class="absolute -bottom-4 text-[10px] opacity-40">Coming Soon</span>
              </div>
              <a href="https://play.google.com/store/apps/details?id=com.tenoctober.hideandseeklostbooks" target="_blank" rel="noopener noreferrer">
                <img
                  src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png"
                  alt="Get it on Google Play"
                  class="h-[60px] -m-2"
                />
              </a>
              <a href="/privacy/lost-books" class="link link-hover text-xs opacity-50 ml-auto">Privacy Policy</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer footer-center p-6 text-sm opacity-60">
      <p>&copy; 2011&ndash;{year} Ten October LLC</p>
    </footer>
  </body>
</html>
