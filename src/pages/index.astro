---
import "../styles/global.css";
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="mytheme">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ten October — Custom Web & Mobile App Development</title>
    <meta name="description" content="Since 2011, Ten October has helped ground-level startups take their web and mobile apps from 0 to 1." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="min-h-screen flex flex-col items-center justify-center px-6">
      <div class="flex flex-col items-center gap-8 max-w-lg w-full">
        <img src="/logo.svg" alt="Ten October" class="w-72" />

        <p class="text-center text-lg leading-relaxed">
          Since 2011, we've helped ground-level startups take their web and
          mobile apps from 0&nbsp;to&nbsp;1.
        </p>

        <a href="mailto:support@tenoctober.com" class="btn btn-primary">
          Get in Touch
        </a>
      </div>
    </main>

    <footer class="footer footer-center p-6 text-sm opacity-60">
      <p>&copy; 2011&ndash;{year} Ten October LLC</p>
    </footer>
  </body>
</html>
